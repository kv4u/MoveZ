{
  "name": "movez",
  "displayName": "MoveZ",
  "description": "Transfer and migrate AI coding sessions between tools and machines",
  "version": "0.1.0",
  "publisher": "movez",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "movez",
          "title": "MoveZ",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "movez": [
        {
          "id": "movezSessions",
          "name": "Sessions",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "movez.exportSession",
        "title": "Export Sessions",
        "category": "MoveZ"
      },
      {
        "command": "movez.importSession",
        "title": "Import Sessions",
        "category": "MoveZ"
      },
      {
        "command": "movez.openMigrationWizard",
        "title": "Migration Wizard",
        "category": "MoveZ"
      },
      {
        "command": "movez.syncPush",
        "title": "Sync Push",
        "category": "MoveZ"
      },
      {
        "command": "movez.syncPull",
        "title": "Sync Pull",
        "category": "MoveZ"
      },
      {
        "command": "movez.refreshSessions",
        "title": "Refresh Sessions",
        "category": "MoveZ",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "movez.refreshSessions",
          "when": "view == movezSessions",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "MoveZ",
      "properties": {
        "movez.cliPath": {
          "type": "string",
          "default": "movez",
          "description": "Path to the movez CLI executable or PHAR file"
        },
        "movez.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of your self-hosted MoveZ sync server"
        },
        "movez.token": {
          "type": "string",
          "default": "",
          "description": "API token for the sync server"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/__tests__/runTests.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
