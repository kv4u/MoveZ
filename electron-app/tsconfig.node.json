{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "outDir": "out/main",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "@main/*": ["./electron/*"]
    }
  },
  "include": ["electron.vite.config.*", "electron/**/*"]
}
